# ---- Database ----
DATABASE_URL="postgresql://clinic:clinic@localhost:5432/digital_clinic?schema=public"

# ---- Auth ----
# Refresh tokens are opaque random bytes, hashed (SHA-256) at rest and
# compared by hash — they are never JWT-signed, so there is no separate
# refresh secret to configure.
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- API ----
API_PORT=4000
API_CORS_ORIGIN="http://localhost:3000"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_DOMAIN="platform.local"

# ---- Storage (S3-compatible / Cloudflare R2) ----
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_REGION="auto"

# ---- Notifications ----
# Email is wired up (apps/api/src/notifications/providers/email.provider.ts,
# via nodemailer) — fill these in to actually send; left blank, email sends
# fail with a recorded, visible reason (see /dashboard/notifications) rather
# than pretending to succeed.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
# SMS/WhatsApp are NOT wired to any provider yet — these two are placeholders
# for whoever adds that (see SmsProvider/WhatsAppProvider), not consumed by
# any code today. Don't expect setting these to do anything until then.
WHATSAPP_API_TOKEN=""
SMS_API_KEY=""

# ---- Cron (scheduled tasks) ----
# Shared secret checked by CronSecretGuard (apps/api/src/cron/) — required
# for POST /api/v1/internal/cron/appointment-reminders, called by an
# external scheduler (e.g. cron-job.org, see README § Deployment). Generate
# a real random value for this in production; the empty default below means
# that route rejects every request until it's set.
CRON_SECRET=""
